<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>雅思精听复习助手 - 真题联动版 v6.0</title>
    <style>
        :root { --primary: #1976d2; --q-color: #e65100; }
        body { font-family: 'PingFang SC', sans-serif; display: flex; flex-direction: column; height: 100vh; margin: 0; background: #f0f2f5; overflow: hidden; }
        
        /* 顶部导航 */
        .top-nav { background: white; padding: 10px 20px; display: flex; gap: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); align-items: center; z-index: 100; }
        
        /* 三栏布局 */
        .container { display: flex; flex: 1; overflow: hidden; gap: 10px; padding: 10px; }
        
        /* 1. 题号导航 */
        .q-nav { width: 150px; background: white; border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 8px; overflow-y: auto; }
        .q-btn { padding: 8px; background: #fff3e0; color: var(--q-color); border: 1px solid #ffe0b2; border-radius: 6px; text-align: center; cursor: pointer; font-weight: bold; font-size: 13px; }
        
        /* 2. 中间原文区 */
        .lyrics-view { flex: 1; display: flex; flex-direction: column; gap: 10px; min-width: 400px; }
        #lyrics-container { flex: 1; background: white; border-radius: 8px; overflow-y: auto; padding: 15px; scroll-behavior: smooth; }
        .line { padding: 12px; border-radius: 6px; cursor: pointer; margin-bottom: 8px; border-left: 4px solid transparent; display: flex; justify-content: space-between; align-items: center; transition: 0.2s; border-bottom: 1px solid #f9f9f9; }
        .line:hover { background: #f5f7fa; }
        .line.active { background: #e3f2fd; border-left-color: var(--primary); font-weight: 500; }
        .line.is-q { background: #fffde7; }
        
        /* 3. 右侧 PDF 展示区 */
        .pdf-view { flex: 1.2; background: #525659; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column; }
        #pdf-frame { width: 100%; height: 100%; border: none; }

        .download-btn { font-size: 11px; padding: 5px 8px; background: #4caf50; color: white; border: none; border-radius: 4px; cursor: pointer; }
        #status-info { font-size: 12px; color: #666; margin-left: auto; }
    </style>
</head>
<body>

<div class="top-nav">
    <strong>IELTS Pro v6.0</strong>
    <div>音频: <input type="file" id="mediaUpload" accept="audio/*"></div>
    <div>教案SRT: <input type="file" id="textUpload" accept=".srt"></div>
    <div id="status-info">等待载入音频以自动关联PDF...</div>
</div>

<div class="container">
    <!-- 1. 题号 -->
    <div class="q-nav" id="qNav"><small style="text-align:center;color:#999">题目跳转</small></div>
    
    <!-- 2. 原文 -->
    <div class="lyrics-view">
        <audio id="audioPlayer" controls style="width: 100%;"></audio>
        <div id="lyrics-container"><div id="lyrics-content"></div></div>
    </div>
    
    <!-- 3. PDF 真题 -->
    <div class="pdf-view">
        <div id="pdf-placeholder" style="color:white; text-align:center; padding-top:100px;">
            载入音频后将自动在此拉取 PDF 真题
        </div>
        <iframe id="pdf-frame" style="display:none;"></iframe>
    </div>
</div>

<script>
    // 【配置中心】在此填入你的 GitHub Pages 基础地址
    const PDF_BASE_URL = "https://你的用户名.github.io/你的仓库名/";

    let lyricsData = [];
    let audioBuffer = null;
    let currentFileName = "";
    const audioPlayer = document.getElementById('audioPlayer');
    const lyricsContent = document.getElementById('lyrics-content');
    const pdfFrame = document.getElementById('pdf-frame');
    const pdfPlaceholder = document.getElementById('pdf-placeholder');

    // 1. 核心逻辑：上传音频后自动关联 PDF
    document.getElementById('mediaUpload').onchange = async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        // 提取文件名 (如 14-2-2)
        currentFileName = file.name.replace(/\.[^/.]+$/, "");
        document.getElementById('status-info').innerText = "当前套题: " + currentFileName;

        // 自动拉取 PDF
        loadPDF(currentFileName);

        // 加载音频流
        audioPlayer.src = URL.createObjectURL(file);
        const arrayBuffer = await file.arrayBuffer();
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        audioBuffer = await audioCtx.decodeAudioData(arrayBuffer);
    };

    function loadPDF(fileName) {
        // 合成 PDF 路径
        const pdfUrl = `${PDF_BASE_URL}${fileName}.pdf`;
        
        pdfPlaceholder.style.display = 'none';
        pdfFrame.style.display = 'block';
        // 加上 #toolbar=0 可以隐藏 PDF 的工具栏，让界面更清爽
        pdfFrame.src = pdfUrl + "#toolbar=0&view=FitH"; 
        
        console.log("正在尝试加载 PDF:", pdfUrl);
    }

    // 2. 加载 SRT
    document.getElementById('textUpload').onchange = (e) => {
        const reader = new FileReader();
        reader.onload = (event) => parseSRT(event.target.result);
        reader.readAsText(e.target.files[0]);
    };

    function parseSRT(text) {
        lyricsData = [];
        const qNav = document.getElementById('qNav');
        qNav.innerHTML = '<small style="text-align:center;color:#999">题目跳转</small>';
        const blocks = text.replace(/\r\n/g, '\n').split(/\n\s*\n/);

        blocks.forEach((block) => {
            const lines = block.trim().split('\n');
            const timeMatch = lines[1]?.match(/(\d{2}):(\d{2}):(\d{2})[,.](\d{3})/);
            if (timeMatch) {
                const time = parseInt(timeMatch[1]) * 3600 + parseInt(timeMatch[2]) * 60 + parseInt(timeMatch[3]) + parseInt(timeMatch[4]) / 1000;
                let content = lines.slice(2).join(' ');
                const qMatch = content.match(/\(Q(.*?)\)/);
                const qNum = qMatch ? qMatch[1] : null;
                
                lyricsData.push({ time, content, q: qNum });

                if (qNum) {
                    const btn = document.createElement('div');
                    btn.className = 'q-btn';
                    btn.innerText = `Q ${qNum}`;
                    btn.onclick = () => { audioPlayer.currentTime = time; audioPlayer.play(); };
                    qNav.appendChild(btn);
                }
            }
        });
        render();
    }

    function render() {
        lyricsContent.innerHTML = '';
        lyricsData.forEach((item, i) => {
            const div = document.createElement('div');
            div.className = `line ${item.q ? 'is-q' : ''}`;
            div.id = `line-${i}`;
            div.innerHTML = `
                <div class="content-text">
                    ${item.q ? `<span class="q-indicator">[Q${item.q}]</span>` : ''}
                    <span style="display:block">${item.content}</span>
                </div>
                ${item.q ? `<button class="download-btn" onclick="downloadFullQuestion(${i}, event)">下载音频</button>` : ''}
            `;
            div.onclick = () => { audioPlayer.currentTime = item.time; audioPlayer.play(); };
            lyricsContent.appendChild(div);
        });
    }

    // 下载逻辑 (保持 v5.2 的安全命名逻辑)
    async function downloadFullQuestion(startIndex, event) {
        event.stopPropagation();
        if (!audioBuffer) return;
        const qRaw = lyricsData[startIndex].q;
        const qSafe = qRaw.replace(/[\\/:*?"<>|]/g, "_"); 
        const startTime = lyricsData[startIndex].time;
        let endTime = audioBuffer.duration;
        for (let j = startIndex + 1; j < lyricsData.length; j++) {
            if (lyricsData[j].q) { endTime = lyricsData[j].time; break; }
        }
        const duration = endTime - startTime;
        const audioCtx = new AudioContext();
        const newBuffer = audioCtx.createBuffer(audioBuffer.numberOfChannels, duration * audioBuffer.sampleRate, audioBuffer.sampleRate);
        for (let channel = 0; channel < audioBuffer.numberOfChannels; channel++) {
            newBuffer.getChannelData(channel).set(audioBuffer.getChannelData(channel).slice(Math.floor(startTime * audioBuffer.sampleRate), Math.floor(endTime * audioBuffer.sampleRate)));
        }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(bufferToWav(newBuffer));
        a.download = `${currentFileName} Q${qSafe}.wav`;
        a.click();
    }

    function bufferToWav(buffer) {
        const length = buffer.length * 2 + 44;
        const view = new DataView(new ArrayBuffer(length));
        const channels = buffer.numberOfChannels;
        const sampleRate = buffer.sampleRate;
        let offset = 0;
        const writeString = (s) => { for (let i = 0; i < s.length; i++) view.setUint8(offset++, s.charCodeAt(i)); };
        writeString('RIFF'); view.setUint32(offset, length - 8, true); offset += 4;
        writeString('WAVE'); writeString('fmt '); view.setUint32(offset, 16, true); offset += 4;
        view.setUint16(offset, 1, true); offset += 2;
        view.setUint16(offset, channels, true); offset += 2;
        view.setUint32(offset, sampleRate, true); offset += 4;
        view.setUint32(offset, sampleRate * channels * 2, true); offset += 4;
        view.setUint16(offset, channels * 2, true); offset += 2;
        view.setUint16(offset, 16, true); offset += 2;
        writeString('data'); view.setUint32(offset, length - offset - 4, true); offset += 4;
        for (let i = 0; i < buffer.length; i++) {
            for (let ch = 0; ch < channels; ch++) {
                let s = Math.max(-1, Math.min(1, buffer.getChannelData(ch)[i]));
                view.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7FFF, true); offset += 2;
            }
        }
        return new Blob([view], { type: 'audio/wav' });
    }

    audioPlayer.ontimeupdate = () => {
        const cur = audioPlayer.currentTime;
        for (let i = 0; i < lyricsData.length; i++) {
            if (cur >= lyricsData[i].time && (!lyricsData[i+1] || cur < lyricsData[i+1].time)) {
                const activeLine = document.getElementById(`line-${i}`);
                if (activeLine && !activeLine.classList.contains('active')) {
                    document.querySelectorAll('.line.active').forEach(el => el.classList.remove('active'));
                    activeLine.classList.add('active');
                    activeLine.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                break;
            }
        }
    };
</script>
</body>
</html>
